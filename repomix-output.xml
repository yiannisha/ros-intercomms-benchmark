  export ROS_DISCOVERY_SERVER=<server-ip>:11811
  export FASTDDS_DEFAULT_PROFILES_FILE=/path/to/fastdds.xml
  export CYCLONEDDS_URI=file:///path/to/cyclonedds.xml
